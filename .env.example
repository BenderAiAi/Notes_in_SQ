# Подключение к MongoDB для раздела «Расторжения Dubai/TRS»
MONGO_URI=mongodb://username:password@host:27017/

MONGO_DB_DEALS=deals_log
MONGO_COLLECTION_DEALS=dubai

MONGO_DB_TRS=TRS_deals
MONGO_COLLECTION_TRS=trs

MONGO_TIMEOUT_MS=7000
MONGO_FIELD_CY=fc_num_on_CY_old

# Порог аномальной ставки как доля номинала: 1.0 = 100%.
RATE_ALERT_THRESHOLD=1.0

# Необязательная папка готовых файлов по умолчанию.
# TERMINATION_OUTPUT_DIR=Z:\DerivativesDesk\Structured Products\trader_assistants\Для СЗ
